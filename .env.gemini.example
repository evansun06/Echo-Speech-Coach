# Gemini API credentials + model settings
GEMINI_API_KEY=...

# Orchestration models
GEMINI_SUBAGENT_MODEL=gemini-2.5-flash-lite
GEMINI_PRIMARY_MODEL=gemini-2.5-pro
GEMINI_SUBAGENT_TEMPERATURE=0.2
GEMINI_PRIMARY_TEMPERATURE=0.1

# Session chat model (streamed chat responses)
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_CHAT_TEMPERATURE=0.2

# Final reconciliation prompt
GEMINI_FLAGSHIP_FINAL_SYSTEM_PROMPT="You are the final speech coaching synthesis model."
