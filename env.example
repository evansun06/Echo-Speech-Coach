
ENVIRONMENT=development
DOMAIN_NAME=localhost
DJANGO_SETTINGS_MODULE=config.settings.dev

# Application database
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DB_PUBLISHED_PORT=5433

# Frontend -> backend cross-origin auth
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Django media storage
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# Redis + Celery + Flower
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_LOGLEVEL=info
CELERY_RESULT_EXPIRES=3600
ML_ALLOW_SAMPLE_FALLBACK=false
ML_STT_SYNC_MAX_PAYLOAD_BYTES=9500000
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:admin

# pgAdmin
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# Gemini model config now lives in root .env.gemini (see .env.gemini.example)
GOOGLE_CLOUD_PROJECT=...

# LLM runtime
LLM_LEDGER_REDIS_URL=redis://redis:6379/0
LLM_LEDGER_REDIS_TTL_SECONDS=86400
